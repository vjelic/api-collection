                  "endColumn": 113,
                  "snippet": {
                    "text": "    user = c.execute(\"SELECT * FROM users WHERE username = '{}' and password = '{}'\".format(username, password)).fetchone()"
                  },
                  "sourceLanguage": "python"
                }
